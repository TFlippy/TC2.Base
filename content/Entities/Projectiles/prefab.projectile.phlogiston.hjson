cluster:
{
	prefab: "fire.phlogiston"
	velocity: [0.000, -8.000]
	offset: [0.000, -0.800]

	radius: 1.480
	spread: 1.000
	speed: 8.000
	count: 1

	speed_modifier_min: 0.240
	speed_modifier_max: 10.700

	lifetime_modifier_min: 0.400
	lifetime_modifier_max: 2.200

	min_explode_lifetime: 0.121
	// flags: reverse_direction, no_velocity_rotate
	flags: reverse_direction, no_velocity_rotate, align_normal
}

