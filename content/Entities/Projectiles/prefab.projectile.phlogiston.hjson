explosive:
{
	damage_type: fire
	damage_type_secondary: phlogiston

	radius: 4.000
	power: 4.500
	damage_entity: 4300.000
	damage_terrain: 7000.000
	smoke_amount: 0.080
	smoke_lifetime_multiplier: 1.250
	smoke_velocity_multiplier: 1.400
	flash_duration_multiplier: 0.850
	flash_intensity_multiplier: 0.800
	shake_multiplier: 0.000
	force_multiplier: 0.300
	stun_multiplier: 0.500
	fire_amount: 0.450
	sparks_amount: 1.000
	smoke_color: "0xffd8d8d8"
	volume: 0.100
	pitch: 0.940
	flags: primed
}

fire:
{
	flicker: 0.070
	radius: 3.000
	intensity: 1.500
	fade: 0.080
	damage_multiplier: 3.500
	ignite_radius_multiplier: 4.000
	damage_type_contact: phlogiston
	damage_type_convection: phlogiston
	smoke_color: "0xaaffffff"
	temperature: 4000.000
	color_tint: [0.883, 0.558, 0.139, 0.971]

	@light:
	{
		color: [1.000, 0.500, 0.200, 1.000]
		offset: [0.000, 0.000]
		scale: [4.000, 4.000]
		intensity: 1.000
		texture: light.circle.03
		size_modifier: 1.100
	}
}

