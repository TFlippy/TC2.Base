$tags: []

projectile:
{
	damage_base: 2500.000
	damage_bonus: 5000.000
	lifetime: 3.000
	ignore_time: 0.250
	damage_type: phlogiston
	hit_mask: world, solid, water, gas
	size: 0.500
	ricochet_count: 0
	gravity: 0.200
	damp: 0.909
	speed_modifier_min: 0.050
	speed_modifier_max: 0.400
	stabilization: 0.150
	flags: no_miss

	@light:
	{
		color: [1.000, 0.800, 0.600, 2.500]
		offset: [-1.000, 0.000]
		scale: [8.000, 4.000]
		intensity: 1.000
		texture: "light.circle.01"
	}
}

transform:
{

}

