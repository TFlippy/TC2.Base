cluster:
{
	prefab: "fire.phlogiston"
	velocity: [0.000, -5.000]
	offset: [0.000, -0.100]

	radius: 0.100
	spread: 0.800
	speed: 1.000
	count: 1

	speed_modifier_min: 0.000
	speed_modifier_max: 0.500

	lifetime_modifier_min: 0.400
	lifetime_modifier_max: 3.200

	min_explode_lifetime: 0.121
	// flags: reverse_direction, no_velocity_rotate
	flags: none
}

