$tags: []

projectile:
{
	damage_base: 1000.000
	damage_bonus: 5000.000
	lifetime: 3.000
	ignore_time: 0.150
	damage_type: phlogiston
	size: 1.000
	ricochet_count: 0
	gravity: 0.400
	damp: 0.509

	@light:
	{
		color: [1.000, 0.800, 0.600, 2.500]
		offset: [0.000, 0.000]
		scale: [6.000, 6.000]
		intensity: 1.000
		texture: "light.circle.01"
	}
}

transform:
{

}

