dormitory:
{
	species: human
	flags: no_kit_selection, no_kit_requirements, region_only, no_gui
	characters_capacity: 6
	repopulate_interval: 900.000
	repopulate_interval_extra: 300.000
	repopulate_num: 1
	repopulate_num_extra: 4
	repopulate_max: 6
	asset_flags: recycle
	character_flags_filter:
	{
		require: none
		include: construction, scientist, criminal, educated, military, medical, artisan, laborer, civillian, law, social, commerce, technician, engineer, miner, hunter, culinary, soldier, alcoholic, nomad, entertainer, artist, thief, lower_middle_class, middle_class
		exclude: slave, lowlife, illiterate, lower_class, upper_class, elite_class
		weight: 1.000
	}
	kit_categories_filter:
	{
		exclude: illegal, explosive, contraband, outlaw
	}
}

office:
{
	flags: enable_invite_company
}

company:
{
	logo_type: sign_4x2

	@light:
	{
		// color: [1.000, 0.750, 0.100, 2.000]
		color: [1.000, 0.750, 0.100, 2.500]
		offset: [-2.875, -1.125]
		scale: [15.000, 20.000]
		intensity: 1.150
		texture: "light.box.01"
	}

	@animated.renderer:
	{
		offset: [-2.750, -2.375]
		z: -295.000
	}
}

packer:
{
	size: [4.000, 5.500]
	offset: [1.500, 0.250]
}

shipment:
{
	type: buffer
	flags: keep_items, no_gui, allow_deposit, allow_withdraw
}

