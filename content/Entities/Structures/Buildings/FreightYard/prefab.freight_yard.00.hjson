$name: "Freight Yard"
$desc:
	'''
	TODO: Desc
	'''
$tags: []

body:
{
	type: static
	
	@shape.polygon:
	{
		points:
		[
			[-4.125, -2.750]
			[-1.000, -2.750]
			[1.500, 3.000]
			[-4.250, 3.000]
		]
		
		mass: 5000.000
		radius: 1.000
		
		material: building_masonry
		
		layer: entity, building, support, ignore_melee
	}

	@shape.line:
	{
		a: [-5.250, 4.000]
		b: [5.250, 4.000]
		offset: [0.000, 0.000]
		friction: 0.920
		elasticity: 0.600
		radius: 0.750
		mass: 1000.000
		material: building_reinforced
		layer: entity, solid, platform, ignore_melee
		mask: world, solid, crate, shipment
		exclude: vehicle, platform, stored, wheel
	}
}

nameable:
{
	tags: industrial, market
	flags: randomize
	type: building
	max_length: 16
}

// health:
// {
// 	max: 180000.000
// }

animated.renderer:
{
	sprite:
	{
		texture: "freight_yard.00"
		mask: "freight_yard.00.mask"
	}
	z: -300.000
}

faction:
{

}

faction.colorable:
{
	intensity_a: 0.600
}

transform:
{

}

building:
{

}

claimable:
{
	flags: no_menu, enable_wololo
}

spawn:
{
	flags: public
}

minimap.marker:
{
	sprite:
	{
		texture: "ui_icons_minimap"
		size: [16, 16]
		frame: [7, 0]
	}

	flags: spawner
}

interactable:
{
	flags: no_tab
	priority: 0.150
	window_size: [726.000, 450.000]
	window_size_misc: [144.000, 0.000]
}

stockpile:
{
	request_types: pack, unpack, move, send, load
	flags: hide_unowned
	grid_column_count: 6
	capacity_items: 12
	capacity_shipments: 9
}

