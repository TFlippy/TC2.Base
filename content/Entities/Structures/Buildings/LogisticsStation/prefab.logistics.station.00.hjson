$name: "Logistics Station"
$desc:
	'''
	TODO: Desc
	'''
$tags: []

body:
{
	type: static
	
	@shape.box:
	{
		size: [2.250, 2.750]
		offset: [0.000, -0.125]
		
		mass: 250.000
		radius: 0.500
		
		material: building_wood
		
		layer: entity, building, support, ignore_melee, ignore_bullet
		mask: world, building
	}
}

animated.renderer:
{
	sprite:
	{
		texture: logistics.station.00
	}
	z: -300.000
}

interactable:
{
	flags: no_tab
	window_size: [810, 632]
	window_size_misc: [96, 0]
	priority: 5.000
}

health:
{
	max: 11000.000
}

faction.colorable:
{
	intensity_a: 0.500
}

faction:
{

}

claimable:
{
	flags: allow_owner_unclaim
}

transform:
{

}

building:
{

}

nameable:
{
	tags: lame, industrial, tool, food, male
	type: building
	flags: randomize
	max_length: 10
}

