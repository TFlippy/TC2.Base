personnel:
{
	characters_capacity: 2
	flags: draw_heads
	assign_radius: 20.000
	
	slots:
	[
		{
			type: undefined
			role: quartermaster
			flags: required
			tags: management, administrative, civil, industrial, logistics, paperwork, sedentary, commerce, financial
			color: "0xff5eaaff"
			multiplier: 1.000
		}
		{
			role: clerk
			flags: faction, controller, eject_on_destroy, can_craft, can_manage, can_use_inventory
			
			tags: administrative, civil, logistics, paperwork, sedentary, commerce, financial
			color: "0x8f005ec2"
			multiplier: 1.000
		}
		null
		null
		null
		null
		null
		null
	]
}

logistics:
{
	linked_capacity: 10
	
	filter_inventory_types: storage, input, output, ammo, waste, workshop
	filter_inventory_flags:
	{
		exclude: hidden
	}
	
	search_rect: [-3.000, -3.000, 3.000, 3.000]

	@inventory8:
	{
		type: buffer
		flags: ignore_mass, vertical
		stack_size_multiplier: 4.000
		
		filter:
		{
			exclude: gas
		}
	}
}