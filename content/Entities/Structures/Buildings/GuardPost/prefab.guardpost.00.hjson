$name: "Guardpost"
$desc:
	'''
	Small building used for storing and managing guards.
	'''
$tags: []

body:
{
	type: static
	
	@shape.box:
	{
		size: [2.250, 2.750]
		offset: [0.000, -0.125]
		
		mass: 550.000
		radius: 0.500
		
		material: building_reinforced
		
		layer: entity, building, support, ignore_melee, ignore_bullet
		mask: world, building
	}
}

animated.renderer:
{
	sprite:
	{
		texture: guardpost.00
	}
	z: -300.000
}

interactable:
{
	flags: no_tab
	window_size: [538, 528]
	window_size_misc: [192, 0]
	priority: 1.000
}

health:
{
	max: 11000.000
}

faction.colorable:
{
	intensity_a: 0.500
}

faction:
{

}

claimable:
{
	flags: allow_owner_unclaim
}

claimer:
{
	radius: 24.000
	strength: 1.500
	falloff: 1.500
}

minimap.marker:
{
	sprite:
	{
		texture: ui_icons_minimap
		size: [16, 16]
		frame: [3, 0]
	}
	flags: faction
}

transform:
{

}

building:
{

}

nameable:
{
	tags: lame, dangerous, industrial, tool, food, male
	type: building
	flags: randomize
	max_length: 10
}

