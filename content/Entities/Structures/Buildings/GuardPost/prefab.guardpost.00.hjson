personnel:
{
	characters_capacity: 2
	flags: draw_heads
	assign_radius: 20.000
	
	slots:
	[
		{
			role: inspector
			flags: required, faction, draw_head, eject_on_destroy, can_craft, can_manage, can_use_inventory
			offset: [-3, -2]
			
			tags: security, management, administrative, civil, military, paperwork, sedentary
			color: "0xff719240"
			multiplier: 1.000
		}
		{
			role: guard
			flags: faction, controller, eject_on_destroy, can_craft, can_manage, can_use_inventory
			
			tags: security, combat, military, dangerous, maintenance, operation
			color: "0xff719240"
			multiplier: 1.000
		}
		null
		null
		null
		null
		null
		null
	]
}

armory:
{
	@inventory4:
	{
		type: ammo
		flags: ignore_mass, no_auto_pickup, faction, vertical
		stack_size_multiplier: 2.000
		
		filter:
		{
			require: ammo, solid
			include: granular, small
			exclude: gas, large
		}

		offset: [0.000, -1.250]
	}
}

shipment:
{
	flags: keep_items, allow_withdraw, allow_deposit, no_gui, faction, no_body_mass
	type: armory
	layout: large
}

guardpost:
{
	flags: search_inventories, search_shipments, search_attached, search_toolbelt
	check_interval: t008
	
	item_hints_blacklist: illegal, explosive, contraband, outlaw
	
	self_hints_blacklist: is_annoying, is_scary
	
	filter_search:
	{
		exclude: world, bounds, zone, essence, fire, gas, static
	}
	search_rect: [-1.250, -1.750, 1.250, 1.250]

	@inventory8:
	{
		type: storage
		flags: standalone, ignore_mass, no_auto_pickup, faction, horizontal
		stack_size_multiplier: 1.000
		
		filter:
		{
			exclude: gas
		}
		offset: [-0.625, 0.875]
	}
}

alarm:
{
	h_sound_start: item.click.03
	h_sound_stop: item.click.04
	sound_volume: 0.500
	rotation_speed: 5.000

	@light:
	{
		color: [0.949541, 0.100181, 0.100181, 1.600]
		offset: [-0.125, -1.625]
		scale: [12.000, 12.000]
		intensity: 0.000
		texture: "light.cone.01"
		rotation: 0.000
	}

	@sound.emitter:
	{
		file: alarm.bell.loop.00
		flags: start_muted
		volume: 0.500
		pitch: 0.800
		size_max_modifier: 1.500
		priority: 0.750
		offset: [-0.125, -1.500]
	}
}