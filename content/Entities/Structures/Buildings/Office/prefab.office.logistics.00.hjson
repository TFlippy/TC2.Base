office:
{
	flags: none
}

address:
{
	
}

entrance.linkable:
{

}

personnel:
{
	characters_capacity: 2
	assign_radius: 20.000

	slots:
	[
		{
			type: undefined
			role: manager
			flags: required
			tags: management, administrative, civil, logistics, paperwork, sedentary, commerce
			color: "0x8f005ec2"
			multiplier: 4.000
		}
		{
			type: undefined
			role: accountant
			flags: none
			tags: administrative, civil, logistics, paperwork, sedentary, commerce, financial
			color: "0x8f005ec2"
			multiplier: 2.000
		}
	]
}

stockpile:
{
	request_types: move, send
	flags: full_access, show_addresses, edit_addresses
	grid_column_count: 8
	capacity_items: 0
	capacity_shipments: 0
}