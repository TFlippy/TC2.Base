$name: "Logistics Office"
$desc:
	'''
	Logistics-oriented bureaucracy is performed here.
	'''
$tags: []

body:
{
	type: static
	
	@shape.box:
	{
		size: [6.000, 5.000]
		offset: [0.000, 0.000]
		mass: 550.000
		friction: 0.500
		elasticity: 0.500
		material: stone_slab
		layer: entity, building, support, ignore_melee, storage
		mask: world
	}
}

health:
{
	max: 14500.000
}

animated.renderer:
{
	sprite:
	{
		texture: "office.logistics.00"
	}
	z: -300.000
}

transform:
{

}

building:
{

}

interactable:
{
	flags: no_tab
	window_size: [676.000, 456.000]
	window_size_min: [192.000, 144.000]
	window_size_misc: [144.000, 0.000]
	window_offset: [0.000, 0.000]
}

faction:
{

}

nameable:
{
	tags: fancy, market
	flags: randomize
	type: location
	max_length: 16
}

claimable:
{
	flags: no_menu
}

