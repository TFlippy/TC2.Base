crafter.state:
{
	@inventory4:
	{
		type: waste
		flags: standalone, allow_ducts, ignore_mass, vertical
		stack_size_multiplier: 4.000
		
		filter:
		{
			exclude: gas
		}
		offset: [0.750, 1.500]
	}
}

axle:
{
	offset: [0.125, -1.000]
	
	friction: 0.200
	radius_inner: 0.500
	radius_outer: 0.750
	z: -315.000
	
	@animated.renderer:
	{
		sprite:
		{
			texture: "wheel_0750.steel"
		}
		z: -200.000
