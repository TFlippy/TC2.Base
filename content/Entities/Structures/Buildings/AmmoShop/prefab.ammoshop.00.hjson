$tags: []

body:
{
	type: static
	
	@shape.box:
	{
		size: [3.250, 3.750]
		offset: [0.000, -0.125]
		
		mass: 820.000
		radius: 0.500
		
		material: building_reinforced
		
		layer: entity, building, support, ignore_melee, ignore_bullet, background
		mask: world, building
	}
}

animated.renderer:
{
	sprite:
	{
		texture: ammoshop.00
	}
	z: -300.000
}

interactable:
{
	flags: no_tab
	priority: 1.000
	window_size: [658.000, 648.000]
	window_size_misc: [144.000, 0.000]
}

health:
{
	max: 88000.000
}

faction.colorable:
{

}

faction:
{

}

claimable:
{
	flags: allow_owner_unclaim
}

transform:
{

}

building:
{

}

nameable:
{
	tags: dangerous, industrial, tool, factory
	type: gun
	flags: randomize
	max_length: 16
}

// address:
// {
	
// }

// entrance.linkable:
// {

// }

laboratory:
{
	blueprints_capacity: 2
	augments_capacity: 10
	filter_tags:
	{
		include: munitions, alchemistry, explosive
	}
}

shop:
{
	tags_filter:
	{
		include: munitions, explosive
		exclude: large, huge, blacksmithing, smelting, drying
	}
	
	tools: pencil, paper, ruler, hammer, cutters, hand_drill, screwdriver, spanner, pliers, tweezers, bucket, shovel, syringe, file, towel, spatula, knife, sandpaper, scissors, ladle
	infrastructure: anvil, lab_glassware, dishes, bottle, table, chair, vise, rack, shaping_mould, bucket, surface, hard_surface, stamping_press, press, structure, machine, building, workbench
	environment: workshop, stationary, scary, noisy, durable, sturdy, flammable, factory
	
	flags: embed_gui
	menu_columns: 4
	recipe_type: workshop
	
	offset_spawn: [0.000, 0.500]
	
	name: "Munitions Workshop"
}

workshop:
{
	orders_capacity: 2
	
	tools: none
	infrastructure: none
	environment: none
	
	gui_info_size_x: 252.000
	max_order_mass: 200.000
	
	h_sound_order_complete: effect.bell.ring.00

	@inventory8:
	{
		type: workshop
		flags: standalone, ignore_mass, public, no_auto_pickup, faction, vertical
		stack_size_multiplier: 2.000
		
		filter:
		{
			exclude: gas
		}
		offset: [-0.625, 0.875]
	}
}

personnel:
{
	characters_capacity: 2
	assign_radius: 20.000
	slots:
	[
		{
			role: engineer
			flags: can_craft, can_manage, can_use_inventory
			tags: management, civil, industrial, logistics, production, manual_labor, paperwork, sedentary, technical, maintenance, operation
			color: "0xffff8333"
			multiplier: 1.000
		}
		{
			role: machinist
			flags: can_craft, can_use_inventory
			tags: civil, industrial, production, dangerous, manual_labor, technical, maintenance, operation
			color: "0xffffa800"
			multiplier: 1.200
		}
		null
		null
		null
		null
		null
		null
	]
}

heat:
{
	temperature_medium: 550.000
	temperature_high: 750.000
	temperature_operating: 798.150
	temperature_breakdown: 900.000
	cool_rate: 8.000
	heat_capacity_extra: 80.000
	heat_capacity_mult: 3.000
	heat_damage_mult: 0.200
	flags: exclude_body_mass, no_smoke, no_gui
	fire_flags: none
	offset: [0.000, 0.250]
	smoke_offset: [0.000, -0.750]
	size: [1.500, 2.000]

	@light:
	{
		offset: [-2.125, 0.250]
		scale: [3.000, 6.000]
		intensity: 2.500
		texture: light.box.02
	}
		
	@sound.emitter:
	{
		file: "overheat_loop"
		flags: start_muted
		volume: 1.000
		pitch: 1.000
	}
}

press:
{
	// slider_offset: [0.000, -1.000]
	// slider_length: 0.500
	speed: 2.200
	load_multiplier: 1.000
	
	// @animated.renderer:
