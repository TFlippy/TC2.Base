lamp:
{
	flicker: 0.100
	
	@light:
	{
		color: [1.000, 0.450, 0.000, 2.500]
		offset: [1.500, -3.750]
		scale: [10.000, 10.000]
		intensity: 1.000
		texture: "light.circle.00"
	}
}

alarm:
{
	h_sound_start: item.click.03
	h_sound_stop: item.click.04
	sound_volume: 0.500
	rotation_speed: 3.000

	@light:
	{
		color: [0.949541, 0.100181, 0.100181, 1.600]
		offset: [1.500, -3.750]
		scale: [24.000, 16.000]
		intensity: 0.000
		texture: "light.cone.01"
		rotation: 0.000
	}

	@sound.emitter:
	{
		file: "effect.buzzer.08"
		channel_type: world
		flags: start_muted
		volume: 1.000
		volume_mult: 0.000
		pitch: 0.830
		pitch_mult: 1.000
		size: 1.000
		size_max_modifier: 3.000
		priority: 0.750
		offset: [-0.250, -4.375]
	}
}

