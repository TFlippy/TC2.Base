animated.renderer:
{
	sprite:
	{
		texture: driller.00
		size: [40, 64]
		frame: [0, 0]
	}
	z: 1000.000
}

transform:
{

}

driller:
{
	@sound.emitter:
	{
		file: flywheel.loop.01
		flags: start_muted
		volume: 1.500
		pitch: 0.900
		size: 1.750
		size_max_modifier: 0.900
		priority: 0.450
		offset: [0.000, -1.375]
	}
}

axle:
{
	offset: [0.625, -1.500]
	
	mass: 20.000
	friction: 0.500
	flags: no_wrap

	@animated.renderer:
	{
		sprite:
		{
			texture: "wheel_1500.steel"
		}
		z: -200.000
	}

	@sound.emitter:
	{
		file: flywheel.loop.01
		flags: start_muted
		volume: 1.500
		pitch: 0.900
		size: 1.750
		size_max_modifier: 0.900
		priority: 0.450
		offset: [0.000, -1.375]
	}
}

crank:
{
	offset: [-1.125, -1.875]
	radius: 0.350
	ratio: 2.000
	max_speed: 8.000

	@animated.renderer:
	{
		sprite:
		{
			texture: atlas.axle.00
			size: [16, 16]
			frame: [10, 0]
		}
		rotation: -0.300
		z: 1.000
	}

	// @sound.emitter:
