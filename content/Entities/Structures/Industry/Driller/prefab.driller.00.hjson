}

interactable:
{
	flags: none
	priority: 0.800
	window_size: [592.000, 592.000]
	window_size_misc: [144.000, 0.000]
}

shipment:
{
	type: crafting
	layout: square
	flags: keep_items, allow_deposit, use_misc, no_empty_deposit, crafting
	color: "0xfff0c63e"
}

heat:
{
	temperature_medium: 650.000
	temperature_high: 900.000
	temperature_ignite: 1837.000
	temperature_operating: 1143.150
	temperature_breakdown: 2050.000
	cool_rate: 7.000
	heat_capacity_extra: 100.000
	heat_damage_mult: 0.400
	smoke_size_mult: 0.700
	smoke_speed_mult: 0.300
	smoke_rise_mult: 0.500
	fire_flags: none
	offset: [0.000, -0.375]
	smoke_offset: [0.000, -2.000]
	size: [0.625, 0.750]

	@light:
	{
		offset: [-0.125, 1.125]
		scale: [28.000, 32.000]
		intensity: 1.000
		texture: light.circle.00
	}

	@sound.emitter:
	{
		file: furnace_loop
		flags: start_muted
		volume: 1.100
		pitch: 1.100
		size_max_modifier: 0.850
		priority: 0.450
		offset: [-0.250, 0.625]
	}
}

