$tags: []

body:
{
	type: static

	@shape.line:
	{
		material: metal
		miss_chance: 0.765
		flags: none
		tags: none
		
		layer: entity, solid, background, building, conductive, magnetic, no_overlapped_placement, ignore_bullet
		mask: world, building, no_overlapped_placement
		exclude: none
		
		mass: 140.000
		radius: 0.750
		friction: 0.600
		elasticity: 0.700
		
		cog_offset: [0.000, 0.000]
		
		a: [0.000, -3.500]
		b: [0.000, 1.750]
		offset: [0.000, 0.000]
	}
		
	@shape.polygon:
	{
		material: building_reinforced
		miss_chance: 0.000
		flags: none
		tags: none
		
		layer: entity, solid, building, ignore_melee, ignore_hover, no_overlapped_placement
		mask: world, solid, building, no_overlapped_placement
		exclude: none
		
		mass: 220.000
		radius: 0.500
		friction: 0.500
		elasticity: 0.500
		
		cog_offset: [0.000, 0.000]
		
		points:
		[
			[-1.000, 0.000]
			[1.000, 0.000]
			[1.000, 1.000]
			[-1.000, 1.000]
		]
	}
}

health:
{
	max: 13500.000
}

