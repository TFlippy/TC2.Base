{
	file: truck_engine_loop
	flags: start_muted
	volume: 0.800
	pitch: 0.400
	size: 0.700
	size_max_modifier: 0.400
}

air.vent|"exhaust":
{
	offset: [-0.125, -1.750]
	rotation: -1.571
	cross_section: 0.150
	leak_ratio: 0.001
	flags: no_gui
	type: exhaust
}

air.vent|"intake":
{
	offset: [0.750, 0.625]
	rotation: 0.000
	cross_section: 0.100
	leak_ratio: 0.117
	flags: no_gui
	type: intake
}

air.container:
{
	volume: 0.240
}

burner:
{
	flags: show_misc
	type: liquid
	area_fuel: 0.250
	area_aux: 0.008854
	temperature_max: 1249.000
	pressure_max: 3.000
	insulation: 0.710

	// @inventory1:
	// {
	// 	stack_size_multiplier: 0.500
	// 	type: fuel
	// 	flags: allow_ducts, ignore_mass
	// 	offset: [-0.250, 1.125]
	// 	filter:
	// 	{
	// 		require: fuel, flammable, solid
	// 		include: granular, small, powder, volatile
	// 		exclude: long, gas, large, bottled
	// 	}
	// }

	@sound.emitter:
	{
		file: burner.burn.solid.loop.01
		flags: start_muted
		volume: 0.900
		pitch: 0.900
		size: 0.475
		size_max_modifier: 0.460
		offset: [-0.500, 0.375]
	}

	@light:
	{
		color: [1.000, 0.500, 0.000, 2.000]
		offset: [0.750, 0.625]
		scale: [14.000, 13.000]
		intensity: 0.000
		texture: "light.circle.04"
	}
}

burner.state:
{
	current_temperature: 300.000

	@inventory1:
	{
		type: fuel
		flags: ignore_mass, no_auto_pickup
		stack_size_multiplier: 0.500
		
		filter:
		{
			require: fuel, flammable, liquid
			include: liquid
			exclude: solid, gas
		}
		offset: [0.875, 0.625]
	}
}

shipment:
{
	type: crafting
	layout: square
	flags: keep_items, allow_deposit, use_misc, no_empty_deposit, crafting, no_body_mass
	color: "0xfff0c63e"
}