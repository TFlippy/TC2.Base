$tags: []

body:
{
	type: static
	
	@shape.polygon:
	{
		points:
		[
			[-1.000, -0.625]
			[1.125, -0.625]
			[1.000, 1.625]
			[-0.875, 1.625]
		]
		
		mass: 220.000
		radius: 0.375
		friction: 0.650
		elasticity: 0.200
		
		material: stone_slab
		miss_chance: 0.702
		
		layer: entity, solid, building, support, ignore_melee, background
		mask: world, building
		exclude: none
	}
}

animated.renderer:
{
	sprite:
	{
		texture: "kiln.00"
		size: [24, 32]
	}
	z: -280.000
}

control:
{

}

health:
{
	max: 23000.000
}

transform:
{

}

interactable:
{
	flags: no_tab
	priority: 1.800
	window_size: [616.000, 616.000]
	window_size_min: [192.000, 96.000]
	window_size_misc: [144.000, 0.000]
	window_offset: [-192.000, 0.000]
}

shop:
{
	tags_filter:
	{
		include: metalworking, metallurgy, cooking, drying, heating, processing, dangerous
		exclude: crafting, complex, advanced, large, huge, assembling, construction, fermenting
	}
	
	tools: hammer, cutters, saw, hand_drill, bucket, axe, shovel, tongs, pick
	infrastructure: oven, rack, shaping_mould, surface, hard_surface, heater, burner, stove, kiln, smokestack, form, structure
	environment: container, stationary, dirty, scary, fireproof, durable, sturdy, enclosed, cramped, waterproof, small
	connotations: none
	
	flags: embed_gui
	menu_columns: 3
	recipe_type: workshop
	
	offset_spawn: [-0.375, -0.125]
	
	name: "Betoniter Kiln"
}

crafter:
{
	flags: no_gui
	
	temperature_max: 1249.000
	pressure_max: 3.000
	
	offset: [-0.375, -0.125]

	@inventory8:
	{		
		type: workshop
		flags: standalone, allow_ducts, ignore_mass, no_auto_pickup, vertical
		stack_size_multiplier: 1.000
		
		filter:
		{
			include: soft, malleable, granular, viscous, small, gravel, powder, bottled
			exclude: gas
		}
		offset: [-0.500, -0.125]
	}
}

workshop:
{
	orders_capacity: 1
	
	gui_info_size_x: 252.000
	max_order_mass: 250.000
	
	h_sound_order_complete: computer.bell.00
}

animated.renderer|"exhaust":
{
	sprite:
	{
		texture: burner.parts.00
		size: [16, 16]
		frame: [0, 1]
	}
	offset: [-0.625, -1.625]
	rotation: 0.000
	z: -285.000
}

