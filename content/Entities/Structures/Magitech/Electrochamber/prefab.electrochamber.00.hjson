$name: "EC-EL Arc-Chamber"
$desc:
	'''
	Sealed reaction chamber utilizing high-energy electric arcs from EC-EL pellets to synthesize gases from atmospheric or piped inputs. 
	'''
$tags: []

body:
{
	type: static
	
	@shape.line:
	{
		material: machine
		miss_chance: 0.835
		flags: none
		tags: huge, thin, hard
		
		layer: entity, solid, building, storage, workshop, crafter, conductive, heatable, magnetic, ignore_melee
		mask: world, building
		exclude: none
		
		mass: 140.000
		radius: 0.875
		friction: 0.600
		elasticity: 0.500
		
		cog_offset: [0.000, 0.000]
		
		a: [0.000, -0.250]
		b: [0.000, 1.625]
		offset: [0.000, 0.000]
	}

	// @shape.polygon:
