interactable:
{
	flags: none
	priority: 1.000
	window_size: [600.000, 528.000]
	window_size_misc: [144.000, 0.000]
}

shipment:
{
	type: crafting
	layout: square
	flags: keep_items, allow_deposit, use_misc, no_empty_deposit, crafting
	color: "0xfff0c63e"
}

essence.container:
{
	stability: 0.870
	frequency: 50.000
	emit_type: projector
	flags: show_gui, allow_edit_rate, allow_edit_frequency
	rate_speed: 0.400
	health_threshold: 0.940
	glow_modifier: 0.800

	@inventory1:
	{
		type: essence
		flags: ignore_mass, no_auto_pickup, faction
		stack_size_multiplier: 0.200
		
		filter:
		{
			require: essence, small, pellet, solid
		}
		offset: [0.000, -1.875]
	}

	@sound.emitter:
	{
		flags: start_muted
		volume: 0.700
		offset: [0.000, 0.625]
		size_max_modifier: 0.450
		doppler: 1.000
	}

	@light:
	{
		offset: [-0.375, 0.375]
		scale: [1.000, 8.000]
		texture: light.box.04
	}
}

heat:
{
	temperature_medium: 800.000
	temperature_high: 1200.000
	temperature_ignite: 1337.000
	temperature_operating: 1243.150
	temperature_breakdown: 1950.000
	cool_rate: 12.000
	heat_capacity_extra: 200.000
	heat_damage_mult: 0.100
	smoke_size_mult: 0.700
	smoke_speed_mult: 0.300
	smoke_rise_mult: 0.500
	flags: exclude_body_mass, no_gui
	fire_flags: none
	offset: [0.000, -1.375]
	smoke_offset: [0.000, -0.875]
	size: [2.000, 1.000]

	@light:
	{
		offset: [-0.125, 1.125]
		scale: [28.000, 13.000]
		intensity: 1.000
		texture: light.circle.00
	}

	@sound.emitter:
	{
		file: overheat_loop
		flags: start_muted
		volume: 1.000
		pitch: 0.680
		size_max_modifier: 0.600
		offset: [0.000, 0.500]
	}
}

