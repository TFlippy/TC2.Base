$name: "Vending Machine"
$desc: 
	'''
	Postus Imperialny's solution to the high turnover rate of vendors in high-risk areas.
	'''

$tags: []

body:
{
	type: dynamic
	flags: none
	tags: solid, angular, complex
	
	fall_damage_multiplier: 0.940
	buoyancy: 0.600
	
	@shape.polygon:
	{
		material: machine
		miss_chance: 0.822
		flags: none
		tags: heavy, large, solid
		
		layer: entity, solid, storage, conductive, magnetic
		mask: world
		exclude: none
		
		mass: 420.000
		radius: 0.500
		friction: 0.700
		elasticity: 0.450
		
		cog_offset: [0.0625, 0.3125]
		
		points:
		[
			[-1.000, -0.625]
			[0.750, -0.875]
			[0.750, 1.375]
			[-0.875, 1.375]
		]
	}
}

transform:
{

}

health:
{
	max: 95000.000
}

armor:
{
	material_type: metal_solid
	coverage: 0.894
	flags: no_damage_type_conversion
	toughness: 700.000
	protection: 0.950
	knockback_modifier: 1.300
	pain_modifier: 0.000
}

animated.renderer:
{
	sprite:
	{
		texture: "vending_machine.00"
	}
	offset: [0.000, 0.000]
	z: -100.000
}

faction:
{

}

claimable:
{
	flags: allow_owner_unclaim, allow_enemy_unclaim
}

company:
{
	h_company: postus
	logo_type: sign_2x1
}

// shop:
// {
