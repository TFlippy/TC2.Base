$name: "Skyhook (Base)"
$desc: "TODO: Desc"
$tags: []

body:
{
	type: kinematic
	
	@shape.circle:
	{
		mass: 500.000
		radius: 1.500
		friction: 0.950
		elasticity: 0.500
		material: metal
		layer: entity
		mask: world
	}
}

transform:
{

}

health:
{
	max: 900000.000
}

animated.renderer:
{
	sprite:
	{
		texture: skyhook.00.atlas
		frame: [0, 0]
		size: [48, 16]
	}
	z: -150.000
}

