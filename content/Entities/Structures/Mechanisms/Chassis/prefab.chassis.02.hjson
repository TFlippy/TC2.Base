+slot.cab|instance:
{
	joint.base:
	{
		offset_a: [0.000, -0.750]
		max_force: 10000000.000
		max_torque: 2000000.000
		flags: control_read, no_wrap, force_facing, attachment, use_proxy_body
		material_type: metal
		z: -10.000
	}

	joint.pivot:
	{
		error_bias: 0.0001
		max_bias: 100.000
	}

	joint.gear:
	{
		error_bias: 0.00001
		max_bias: 10.000
		min: 0.000
		max: 0.000
	}

	attachment.slot:
	{
		name: "Cabin"
		identifier: "cabin"

		flags: keyboard_read, mouse_read
		flags_editable: use_center_of_gravity, locked, disabled, keyboard_read, keyboard_write, mouse_read, mouse_write, offset, rotation

		offset_bounds: [-1.000, -1.000, 1.000, 1.000]

		rank: -20.000
		gui_size: [144.000, 144.000]
	}
}

+slot.mid|instance:
{
	joint.base:
	{
		offset_a: [0.000, -0.250]
		max_force: 10000000.000
		max_torque: 200000.000
		flags: control_write, control_read, no_wrap, force_facing, attachment, use_proxy_body
		z: -50.000
	}

	joint.pivot:
	{
		error_bias: 0.01
		max_bias: 100.000
	}

	joint.gear:
	{
		error_bias: 0.01
		max_bias: 2.000
		min: 0.000
		max: 0.000
	}

	attachment.slot:
	{
		flags: keyboard_write, mouse_write
		flags_editable: locked, disabled, hold, invert, cycle, keyboard_read, keyboard_write, mouse_read, mouse_write
		
		rank: 11.000
		
		gui_size: [288.000, 72.000]
		
		identifier: "mid"
		name:
			'''
			Rotary Mount
			Mid
			'''
	}
}

+slot.bottom|instance:
{
	joint.base:
	{
		offset_a: [0.000, 0.500]
		max_force: 10000000.000
		max_torque: 200000.000
		flags: control_write, control_read, no_wrap, force_facing, attachment, use_proxy_body
		z: -60.000
	}

	joint.pivot:
	{
		error_bias: 0.01
		max_bias: 100.000
	}

	joint.gear:
	{
		error_bias: 0.01
		max_bias: 2.000
		min: 0.000
		max: 0.000
	}

	attachment.slot:
	{
		flags: keyboard_write, mouse_write
		flags_editable: locked, disabled, invert, keyboard_read, keyboard_write, mouse_read, mouse_write
		tags_filter:
		{
			include: turret, propulsion, box, fixed
			exclude: tiny, platform
		}
		
		rank: 22.000
		
		gui_size: [96.000, 72.000]
		
		identifier: "bottom"
		name:
			'''
			Fixed Mount
			Bottom
			'''
	}
}

+slot.left|instance:
{
	joint.base:
	{
		offset_a: [-2.250, 0.250]
		z: -10.000
		max_force: 500000.000
		max_torque: 80000.000
		
		material_type: metal
		
		flags: attachment, allow_dragging, control_write, facing_reset_rot, facing_reset_pos, force_facing, mirror_x
	}

	joint.pivot:
	{
		error_bias: 0.0001
		max_bias: 25.000
	}

	joint.gear:
	{
		error_bias: 0.001
		max_bias: 5.000
		min: 0.000
		max: 0.000
	}

	attachment.slot:
	{
		flags: hold, keyboard_write, mouse_write
		flags_editable: locked, disabled, hold, invert, cycle, keyboard_read, keyboard_write, mouse_read, mouse_write, brake, rotation
		tags_filter:
		{
			include: rotary
			exclude: tiny, huge, motor, platform
		}
		
		rank: 21.000
		
		gui_size: [96.000, 72.000]
		
		identifier: "left"
		name:
			'''
			Rotary Mount
			Left
			'''
	}

	facing:
	{
		flags: use_rotation
		offset: 0.000
		threshold: 0.050
		flip_interval: 0.500
	}
}

+slot.right|instance:
{
	joint.base:
	{
		offset_a: [2.250, 0.250]
		z: -10.000
		max_force: 500000.000
		max_torque: 80000.000
		
		material_type: metal
		
		flags: attachment, allow_dragging, control_write, facing_reset_rot, facing_reset_pos, force_facing
	}

	joint.pivot:
	{
		error_bias: 0.0001
		max_bias: 25.000
	}
	
	joint.gear:
	{
		error_bias: 0.001
		max_bias: 5.000
		min: 0.000
		max: 0.000
	}

	attachment.slot:
	{
		flags: hold, keyboard_write, mouse_write
		flags_editable: locked, disabled, hold, invert, cycle, keyboard_read, keyboard_write, mouse_read, mouse_write, brake, rotation
		tags_filter:
		{
			include: rotary
			exclude: tiny, huge, motor, platform
		}
		
		rank: 23.000
		
		gui_size: [96.000, 72.000]
		
		identifier: "right"
		name:
			'''
			Rotary Mount
			Right
			'''
	}

	facing:
	{
		flags: use_rotation
		offset: 0.000
		threshold: 0.050
		flip_interval: 0.500
	}
}


