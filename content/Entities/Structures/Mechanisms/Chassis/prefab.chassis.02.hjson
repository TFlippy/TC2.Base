// 	protection: 0.500
	
// 	knockback_modifier: 1.300
// 	pain_modifier: 0.000

// 	material_type: metal
// 	flags: no_damage_type_conversion
// }

animated.renderer:
{
	sprite:
	{
		texture: "chassis.02.bg"
	}
	offset: [0.000, 0.000]
	z: -100.000
}

vehicle:
{
	@animated.renderer:
	{
		sprite:
		{
			texture: "chassis.02.fg"
		}
		z: 100.000
	}
}

holdable:
{
	radius: 0.000
	stress_multiplier: 0.500
	flags: disable_parent_facing, disable_rotation, disable_control
}

attachment:
{
	offset: [0.000, -0.125]
	tags: large, mount, platform, fixed
	flags: disable_parent_facing
}

transform:
{

}

control:
{
	// @net.synchronized:
	// {
	// 	interval: 0.000
	// }

	@net.synchronized:
	{
		interval: 0.000
	}
}

norotate:
{
	multiplier: 0.400
	bias: 0.200
	mass_multiplier: 25.000
	flags: no_share
}

interactable:
{
	flags: none
	window_size: [288, 288]
	window_size_misc: [96, 0]
	priority: 1.500
	window_offset: [0.000, -200.000]
}

