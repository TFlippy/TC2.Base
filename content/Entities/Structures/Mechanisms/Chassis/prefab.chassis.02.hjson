$name: "Platform Chassis"
$desc:
	'''
	TODO: Desc
	'''
$tags: []

body:
{
	gravity: 1.000
	fall_damage_multiplier: 0.500

	@shape.polygon:
	{
		material: metal_frame
		miss_chance: 0.361
		flags: none
		tags: none
		
		layer: entity, solid, vehicle
		mask: world
		exclude: tree
		
		mass: 710.000
		radius: 0.500
		friction: 0.900
		elasticity: 0.850
		
		cog_offset: [0.000, 0.000]
		
		points:
		[
			[-2.250, 0.000]
			[2.250, 0.000]
			[1.375, 0.750]
			[-1.375, 0.750]
		]
	}

	@shape.line:
	{
		material: metal
		miss_chance: 0.000
		flags: none
		tags: none
		
		layer: entity, solid, vehicle, platform
		mask: world, solid
		exclude: tree, wheel, attached
		
		mass: 80.000
		radius: 0.4375
		friction: 0.800
		elasticity: 0.450
		
		cog_offset: [0.000, 0.000]
		
		a: [-2.250, -0.500]
		b: [2.250, -0.500]
		offset: [0.000, 0.000]
	}
}

health:
{
	max: 96000.000
}

damage.effects:
{
	threshold_wreck: 0.450
}

