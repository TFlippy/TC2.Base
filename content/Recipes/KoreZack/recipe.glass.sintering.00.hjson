							difficulty: 6
							step_max: 40
							snapping: 25.000
							falloff: 0.964
							group: 0
							flags: stepped, conditional
						}
					]
					
					start_delay: 0.000
					advance_delay: 0.000
					complete_delay: 0.000
				}
			]
		}
	]
	
