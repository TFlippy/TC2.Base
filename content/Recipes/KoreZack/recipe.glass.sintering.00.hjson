{
	$version: "0.1.70.1"
	$author: "KoreZack"
	name: "Glass Sintering"
	desc:
		'''
		Simple glass production process utilizing already powdered glass as feedstock. 

		The powder is heated to a high temperature and fused together to form solid glass panels.
		'''
	
	related_materials:
	{
		glass: flattened, solidified, product, result, manufactured, processed
		glass.powder: ruined, residue, source, waste, powdered, ingredient, result, byproduct
	}
	
	stages:
	[
		{
			name: "Feedstock"
			
			type: feedstock
			flags: important
			tags: material, formula, ingredient
			// Damage type used for discarding leftover resources.
			discard_damage_type: sledgehammer
			
			ratio: 0.000
			mass_base: 0.000
			
			options:
			[
				{
					name: "Standard"
					
					type: undefined
					flags: none
					
					requirements:
					[
						{
							type: resource
							material: glass.powder
							amount: 5.000
							snapping: 1.000
							loss: 0.988
							group: 0
							flags: prerequisite
						}
					]
				}
			]
		}
		{
			name: "Processing"
			
			type: processing
			flags: none
			tags: thin, flat, dangerous, formula
			// Damage type used for discarding leftover resources.
			discard_damage_type: fracture
			
			ratio: 0.000
			mass_base: 0.000
			
