explosive:
{
	radius: 5.000
	power: 5.500
	damage_entity: 6000.000
	damage_terrain: 8000.000
	health_threshold: 0.980
	detonate_chance: 0.980
	damage_type: explosion
	damage_type_secondary: shrapnel
	force_multiplier: 0.900
	stun_multiplier: 0.950
	smoke_amount: 0.900
	smoke_lifetime_multiplier: 0.750
	smoke_velocity_multiplier: 7.000
	flash_duration_multiplier: 0.150
	flash_intensity_multiplier: 1.100
	sparks_amount: 2.500
	volume: 1.950
	pitch: 1.200
	flags: any_damage, explode_when_primed
}

cluster:
{
	prefab: "projectile.ac.he"
	velocity: [0.000, 0.000]
	offset: [0.000, -1.000]
	radius: 0.010
	spread: 5.000
	speed: 20.000
	count: 4
	damage_modifier: 0.750
	speed_modifier_min: 0.800
	speed_modifier_max: 1.400
	lifetime_modifier_min: 0.200
	lifetime_modifier_max: 0.400
	flags: no_velocity_rotate, align_normal
}