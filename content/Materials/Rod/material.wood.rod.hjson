		// Percentage of nitrogen.
		nitrogen_ratio: 0.079
		// Percentage of oxygen.
		oxygen_ratio: 0.090
		// Percentage of sulfur.
		sulfur_ratio: 0.007
		// Percentage of water.
		water_ratio: 0.132
		
		// Percentage of volatiles.
